{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CoreSync: Start development server",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting",
          "endsPattern": "Ready"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "CoreSync: Production build",
      "type": "npm",
      "script": "build",
      "problemMatcher": "$tsc",
      "group": "build"
    },
    {
      "label": "CoreSync: Check code",
      "type": "npm",
      "script": "lint",
      "problemMatcher": "$eslint-stylish",
      "group": "test"
    }
  ]
}
